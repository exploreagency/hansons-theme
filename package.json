{
  "name": "venture-theme",
  "version": "0.1.0",
  "description": "Extensible theme template for rapid landing page/microsite building.",
  "author": "Explore Agency",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "WordPress",
    "Theme"
  ],
  "homepage": "https://github.com/exploreagency/venture-theme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exploreagency/venture-theme.git"
  },
  "bugs": {
    "url": "https://github.com/exploreagency/venture-theme/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@wordpress/scripts": "^19.2.2",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "dir-archiver": "^1.1.1",
    "glob": "^11.0.3",
    "mini-css-extract-plugin": "^2.9.4",
    "node-sass": "^7.0.1",
    "rtlcss": "^3.5.0",
    "sass": "^1.92.1",
    "sass-loader": "^16.0.5",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "webpack-remove-empty-scripts": "^1.1.1"
  },
  "rtlcssConfig": {
    "options": {
      "autoRename": false,
      "autoRenameStrict": false,
      "blacklist": {},
      "clean": true,
      "greedy": false,
      "processUrls": false,
      "stringMap": []
    },
    "plugins": [],
    "map": false
  },
  "scripts": {
    "build": "webpack --mode production",
    "watch": "node-sass sass/ -o ./ --source-map true --output-style expanded --indent-type tab --indent-width 1 -w",
    "compile:css": "node-sass sass/ -o ./ && stylelint '*.css' --fix || true && stylelint '*.css' --fix",
    "compile:rtl": "rtlcss style.css style-rtl.css",
    "lint:scss": "wp-scripts lint-style 'sass/**/*.scss'",
    "lint:js": "wp-scripts lint-js 'js/*.js'",
    "bundle": "dir-archiver --src . --dest ../_s.zip --exclude .DS_Store .stylelintrc.json .eslintrc .git .gitattributes .github .gitignore README.md composer.json composer.lock node_modules vendor package-lock.json package.json .travis.yml phpcs.xml.dist sass style.css.map yarn.lock"
  },
  "dependencies": {
    "alpinejs": "^3.13.9",
    "embla-carousel": "^8.0.2",
    "embla-carousel-autoplay": "^8.1.6",
    "embla-carousel-fade": "^8.1.6"
  }
}